APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/universal_service
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
REDIS_URL=redis://redis:6379/0
SECRET_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
SESSION_ENCRYPTION_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
USER_WEBAPP_URL=http://localhost:8000/app
ADMIN_WEBAPP_URL=http://localhost:8000/admin
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
WEB_SESSION_TTL_SECONDS=3600
WEB_RATE_LIMIT_PER_MINUTE=60
MAX_RECEIPT_BYTES=10485760
CORS_ALLOWED_ORIGINS=http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1
TELEGRAM_BOT_TOKEN=REPLACE_WITH_SERVER_SECRET
PAYMENT_CARD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
PAYMENT_REVIEW_CHAT_ID=
PAYMENT_REVIEW_NOTIFY_SUPERADMINS=true
PAYMENT_REVIEW_NOTIFY_ADMINS=true
SUPERADMIN_IDS=123456789
INITIAL_ADMIN_IDS=
# Keys: contest, topup, account, stars, premium, gift, farm, rating,
# profile, confirm, reject, cancel, enable, disable. Values are numeric IDs.
BUTTON_CUSTOM_EMOJI_IDS={}
DIRECT_SALES_ENABLED=false
QUOTE_TTL_SECONDS=300
PRICING_REQUIRES_SUPERADMIN_APPROVAL=false
MIN_PROFIT_PERCENT=0
MIN_PROFIT_SOM=0
EXPECTED_ALEMBIC_HEAD=20260723_0011
# ISO-8601 timestamp of the latest verified restore-capable backup (must be <24h old).
BACKUP_VERIFIED_AT=
# Set true only after previously exposed production secrets have been rotated.
SECRETS_ROTATED_AFTER_COMPROMISE=false
MAINTENANCE_MODE=false
